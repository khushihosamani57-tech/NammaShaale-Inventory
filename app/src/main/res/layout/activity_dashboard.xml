<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning 👋"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSubGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="School Inventory Dashboard"
                android:textColor="#DCEBFF"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- NOTIFICATION / PROFILE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileCard"
            android:layout_width="54dp"
            android:layout_height="54dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#33FFFFFF"
            app:cardElevation="2dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="13dp"
                android:src="@drawable/ic_notification"
                app:tint="#FFFFFF"
                android:contentDescription="Notification"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- MAIN SCROLL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-35dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- HERO CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashboard_hero"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50"
                            android:textColor="#FFFFFF"
                            android:textSize="58sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Registered Assets"
                            android:textColor="#DCEBFF"
                            android:textSize="14sp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦"
                        android:textSize="56sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- STATUS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- WORKING -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWorking"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="24dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <View android:id="@+id/dotWorking" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bg_green_dot"/>
                        <TextView android:id="@+id/tvCountWorking" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="42" android:textColor="#10B981" android:textSize="26sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvLabelWorking" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Working" android:textColor="#6B7280" android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- REPAIR -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRepair"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="24dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <View android:id="@+id/dotRepair" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bg_orange_dot"/>
                        <TextView android:id="@+id/tvCountRepair" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="5" android:textColor="#F59E0B" android:textSize="26sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvLabelRepair" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Repair" android:textColor="#6B7280" android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BROKEN -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBroken"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="24dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                        <View android:id="@+id/dotBroken" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bg_red_dot"/>
                        <TextView android:id="@+id/tvCountBroken" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="3" android:textColor="#EF4444" android:textSize="26sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvLabelBroken" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Broken" android:textColor="#6B7280" android:textSize="12sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- QUICK ACTIONS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="QUICK ACTIONS"
                android:textColor="#475569"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <!-- FIRST ROW -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal">
                <!-- OPEN ISSUES -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIssues"
                    android:layout_width="0dp" android:layout_height="190dp" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardCornerRadius="28dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp">
                        <ImageView android:id="@+id/ivIconIssues" android:layout_width="58dp" android:layout_height="58dp" android:src="@drawable/ic_issue"/>
                        <TextView android:id="@+id/tvTitleIssues" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Open Issues" android:textSize="18sp" android:textStyle="bold"/>
                        <!-- IDs for DashboardActivity compatibility -->
                        <TextView android:id="@+id/tvActionStatus" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/tvActionBadge" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- REPAIR -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRepairs"
                    android:layout_width="0dp" android:layout_height="190dp" android:layout_weight="1" android:layout_marginStart="8dp" app:cardCornerRadius="28dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp">
                        <ImageView android:id="@+id/ivIconRepairs" android:layout_width="58dp" android:layout_height="58dp" android:src="@drawable/ic_repair"/>
                        <TextView android:id="@+id/tvTitleRepairs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Repair" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvActionStatus2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/tvActionBadge2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- SECOND ROW -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                <!-- HEALTH CHECK -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHealthCheck"
                    android:layout_width="0dp" android:layout_height="190dp" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardCornerRadius="28dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp">
                        <ImageView android:id="@+id/ivIconHealth" android:layout_width="58dp" android:layout_height="58dp" android:src="@drawable/ic_health"/>
                        <TextView android:id="@+id/tvTitleHealth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Health Check" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvActionStatus3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/tvActionBadge3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ASSETS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAssets"
                    android:layout_width="0dp" android:layout_height="190dp" android:layout_weight="1" android:layout_marginStart="8dp" app:cardCornerRadius="28dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="20dp">
                        <ImageView android:id="@+id/ivIconAssets" android:layout_width="58dp" android:layout_height="58dp" android:src="@drawable/ic_assets"/>
                        <TextView android:id="@+id/tvTitleAssets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Assets" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvActionStatus4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/tvActionBadge4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- RECENT ACTIVITY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="RECENT ACTIVITY"
                android:textColor="#475569"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/recentActivityContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">
                <!-- Static Fallback Item -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" app:cardCornerRadius="24dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:padding="18dp">
                        <ImageView android:layout_width="70dp" android:layout_height="70dp" android:src="@drawable/img_microscope" android:scaleType="centerCrop" android:contentDescription="Microscope"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Microscope" android:textSize="17sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Science Lab Equipment" android:textColor="#6B7280"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>